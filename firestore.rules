rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The unique ID of the user.
    //   - email: string (required) - The user's email address.
    //   - displayName: string (optional) - The user's display name.
    //   - photoURL: string (optional) - The user's profile photo URL.
    //   - role: string (required) - The user's role in the application (admin/user).
    //   - createdAt: timestamp (optional) - When the user was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gougou93120@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
        data.uid is string &&
        data.email is string &&
        data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid &&
                      (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && 
                      isValidUser(request.resource.data) && 
                      isOwner(userId) &&
                      request.resource.data.role == resource.data.role; // Cannot change own role
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
