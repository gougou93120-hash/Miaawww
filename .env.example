# OPENAI_API_KEY: Required for server-side AI analysis and chat.
# Keep this value on the server only. Do not expose it in client code.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: Optional. Defaults to gpt-4o.
OPENAI_MODEL="gpt-4o"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STRIPE_SECRET_KEY: Your Stripe Secret Key for payments (sk_test_...)
STRIPE_SECRET_KEY=""

# STRIPE_WEBHOOK_SECRET: (Optional) Secret to verify Stripe webhooks (whsec_...)
STRIPE_WEBHOOK_SECRET=""

# STRIPE_PRICE_MONTHLY_ID: The ID of your monthly subscription price (price_...)
STRIPE_PRICE_MONTHLY_ID=""

# STRIPE_PRICE_YEARLY_ID: The ID of your yearly subscription price (price_...)
STRIPE_PRICE_YEARLY_ID=""
